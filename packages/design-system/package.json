{
  "name": "@pinky/design-system",
  "version": "0.1.0",
  "description": "Pinky React component library built on shadcn/ui",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @pinky/contracts build && tsc",
    "typecheck": "pnpm --filter @pinky/contracts build && tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "echo 'no tests yet'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pinky/contracts": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
