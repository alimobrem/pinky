# Database
PINKY_DATABASE__URL=postgresql+asyncpg://pinky:pinky@localhost:5432/pinky
PINKY_DATABASE_URL=postgresql://pinky:pinky@localhost:5432/pinky

# Redis
PINKY_REDIS__URL=redis://localhost:6379/0

# Encryption (required — generate with: python3 -c "import os; print(os.urandom(32).hex())")
PINKY_ENCRYPTION_KEY=

# Auth - OpenShift OAuth
PINKY_AUTH__OPENSHIFT_ISSUER_URL=https://oauth-openshift.apps.your-cluster.example.com
PINKY_AUTH__OPENSHIFT_CLIENT_ID=pinky
PINKY_AUTH__OPENSHIFT_CLIENT_SECRET=

# Auth - External OIDC (optional)
PINKY_AUTH__OIDC_ISSUER_URL=
PINKY_AUTH__OIDC_CLIENT_ID=
PINKY_AUTH__OIDC_CLIENT_SECRET=

# Auth - General
PINKY_AUTH__CALLBACK_BASE_URL=http://localhost:8000
PINKY_AUTH__SESSION_IDLE_TIMEOUT_MINUTES=30
PINKY_AUTH__SESSION_ABSOLUTE_TIMEOUT_HOURS=8

# LLM (Vertex AI — used by default)
ANTHROPIC_VERTEX_PROJECT_ID=
CLOUD_ML_REGION=global

# LLM (Direct API — fallback)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Worker
PINKY_OBSERVER_ENABLED=true
PINKY_TEMPORAL_ENABLED=true
PINKY_WEBHOOKS_ENABLED=true
PINKY_SCAN_INTERVAL=60

# General
PINKY_DEBUG=false
PINKY_LOG_LEVEL=INFO
PINKY_DEV_AUTH_BYPASS=false
