# Database
PINKY_DATABASE__URL=postgresql+asyncpg://pinky:pinky@localhost:5432/pinky

# Redis
PINKY_REDIS__URL=redis://localhost:6379/0

# Auth
PINKY_AUTH__SESSION_IDLE_TIMEOUT_MINUTES=30
PINKY_AUTH__SESSION_ABSOLUTE_TIMEOUT_HOURS=8

# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=pinky

# General
PINKY_DEBUG=false
PINKY_LOG_LEVEL=INFO
